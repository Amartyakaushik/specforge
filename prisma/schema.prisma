generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Generation {
  id          String   @id @default(cuid())
  prompt      String
  status      String   @default("pending") // pending | processing | completed | failed
  intent      Json?
  design      Json?
  schema      Json?
  refined     Json?
  validation  Json?
  repairs     Json?
  metrics     Json?
  finalConfig Json?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model EvalRun {
  id          String   @id @default(cuid())
  datasetName String
  results     Json
  summary     Json
  createdAt   DateTime @default(now())

  @@index([datasetName])
}
